        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/v1GetAllAlertRuleTemplatesRequest"
            }
          }
        ],
        "tags": [
          "RetrievalAPI"
        ],
        "produces": [
          "application/json"
        ]
      }
    },
    "/v1/check/GetAllChecks": {
      "post": {
        "summary": "Get all checks",
        "description": "Retrieves all check scripts a user is entitled to according to the tier.",
        "operationId": "RetrievalAPI_GetAllChecks",
        "responses": {
          "200": {
            "description": "A successful response.",
